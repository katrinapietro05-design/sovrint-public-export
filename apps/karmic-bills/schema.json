{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovrint.example/schemas/karmic-bill-v1.json",
  "title": "SOVRINT Karmic Bill",
  "type": "object",
  "required": ["id", "title", "description", "category", "status", "direction", "priority", "createdAt", "updatedAt", "history"],
  "properties": {
    "id": { "type": "string", "pattern": "^KB-[0-9]{4}-[0-9]{3,}$" },
    "title": { "type": "string", "minLength": 1, "maxLength": 140 },
    "description": { "type": "string", "minLength": 1 },
    "category": { "enum": ["Accountability", "Care", "Commitment", "Exchange", "Financial", "Harm", "Labour", "Promise", "Responsibility", "Trust", "Other"] },
    "status": { "enum": ["Draft", "Open", "Acknowledged", "In Repair", "Disputed", "Fulfilled", "Closed", "Archived"] },
    "direction": { "enum": ["Owed to me", "Owed by me", "Mutual", "Institutional", "Collective"] },
    "priority": { "enum": ["Low", "Medium", "High", "Critical"] },
    "parties": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "relationship": { "type": "string" },
    "originEvent": { "type": "string" },
    "eventDate": { "type": "string" },
    "dueDate": { "type": "string" },
    "owner": { "type": "string" },
    "monetaryValue": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "nonMonetaryValue": { "type": "string" },
    "impact": { "enum": ["Low", "Moderate", "High", "Severe"] },
    "urgency": { "enum": ["Low", "Moderate", "High", "Immediate"] },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "lineage": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "repairPlan": { "type": "string" },
    "repairActions": { "type": "array", "items": { "type": "string" } },
    "acknowledgements": { "type": "string" },
    "closureCriteria": { "type": "string" },
    "closureStatement": { "type": "string" },
    "closureDate": { "type": "string" },
    "linkedRecords": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "archived": { "type": "boolean" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "action", "detail"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "action": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "Closed" } }, "required": ["status"] },
      "then": {
        "required": ["closureCriteria", "closureStatement", "closureDate"],
        "properties": {
          "closureCriteria": { "type": "string", "minLength": 1 },
          "closureStatement": { "type": "string", "minLength": 1 },
          "closureDate": { "type": "string", "minLength": 1 }
        }
      }
    }
  ],
  "additionalProperties": true
}
